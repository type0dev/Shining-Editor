Imports System.Collections.Generic

''' <summary>
''' Named save field entry used by the editor dropdowns.
''' </summary>

Public Class XC2NamedField
    Public Property Name As String
    Public Property Data As HexDataInfo

    Public Overrides Function ToString() As String
        Return Name
    End Function
End Class

''' <summary>
''' Information required to read a Shining Resonance Refrain save file.
''' </summary>

Public Class XC2Data
    Private Shared Function CreateField(name As String, offset As Integer, size As Integer) As XC2NamedField
        Return New XC2NamedField With {
            .Name = name,
            .Data = New HexDataInfo With {
                .Offset = offset,
                .Size = size,
                .ToSaveFileValue = FieldConversions.FromSimpleDecimal,
                .ToHumanReadableValue = FieldConversions.ToSimpleDecimal
            }
        }
    End Function

    Public Shared ReadOnly PlayerInfoOffsets As New List(Of XC2NamedField) From {
        CreateField("Money", &HD080, &H4)
    }

